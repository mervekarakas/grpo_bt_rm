# Experiment 3: Score-only RL (no reasoning tokens) + graded reward
# Tests whether reasoning-token noise is a major factor
# Uses shorter max_completion_length since output is just a number
export DATASET="${DATASET:-/data/$USER/datasets/grpo_bt_hh_train_hh_score100_scoreonly.jsonl}"
export OUT_DIR="${OUT_DIR:-/data/$USER/experiments/grpo_bt_rm/hh_exp3_scoreonly_graded}"

export MODEL="${MODEL:-Qwen/Qwen2.5-7B-Instruct}"

export PLUGIN="${PLUGIN:-src/grpo_bt_rm/training/reward_plugins/bt_graded.py}"
export REWARD_NAME="${REWARD_NAME:-bt_pointwise_graded}"

export BT_SCORE_PARSER="${BT_SCORE_PARSER:-score100_last}"
export BT_SCORE_TEMP="${BT_SCORE_TEMP:-20}"
export BT_GRADE_THRESH="${BT_GRADE_THRESH:-0.1}"
export BT_REWARD_LOW="${BT_REWARD_LOW:-1.2}"
export BT_REWARD_HIGH="${BT_REWARD_HIGH:-1.4}"
export BT_REWARD_WRONG="${BT_REWARD_WRONG:-0.0}"
export BT_REWARD_PARSE_FAIL="${BT_REWARD_PARSE_FAIL:--0.5}"

export TEMPERATURE="${TEMPERATURE:-1.0}"
export NUM_GENERATIONS="${NUM_GENERATIONS:-8}"
export MAX_COMPLETION_LENGTH="${MAX_COMPLETION_LENGTH:-16}"
export MAX_NEW_TOKENS="${MAX_NEW_TOKENS:-16}"

export LEARNING_RATE="${LEARNING_RATE:-5e-6}"
export MAX_STEPS="${MAX_STEPS:-6000}"
export SAVE_STEPS="${SAVE_STEPS:-500}"

export EXTRA_ARGS="${EXTRA_ARGS:---min_reward_std 0.05}"

export EVAL_DATASET="${EVAL_DATASET:-anthropic_hh}"
export EVAL_PROMPT="${EVAL_PROMPT:-hh_score100_scoreonly}"
export EVAL_PARSER="${EVAL_PARSER:-score100_last}"
export EVAL_BT_TEMP="${EVAL_BT_TEMP:-5}"
